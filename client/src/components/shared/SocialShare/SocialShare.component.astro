---
import BasicButton from '../button/BasicButton/BasicButton.component.astro';
import { texts } from '~/content/texts';

interface Props {
  url?: string;
  shareMessage?: string;
  isJustIcon?: boolean;
  className?: string;
}

const { url, shareMessage: shareMessageProp, isJustIcon, className } = Astro.props;

const sharePath = url || Astro.url.pathname;
const shareTitle = shareMessageProp ?? texts.innovation.shareMessage;
---

<div class="social-share-container group relative overflow-visible" data-share-path={sharePath} data-share-title={shareTitle}>
  <BasicButton
    {...isJustIcon ? {} : { text: 'Share to social network' }}
    hasIcon
    icon="pi pi-share-alt"
    classList={`w-full justify-center border-accent-300 !text-accent-300 mb-2 hover:!bg-accent-300 hover:!text-white cursor-pointer ${className}`}
  />
  {isJustIcon && <div class="invisible-hover-extension absolute top-0 -bottom-4 -left-3 z-0 w-8" />}
  <div class={`dropdown-wrapper hidden group-hover:block absolute top-full w-full pt-1 z-10`}>
    <div
      class={`social-share-dropdown bg-white border border-border-light rounded-lg shadow-lg ${isJustIcon ? 'w-max absolute right-0' : 'overflow-hidden w-full'}`}>
      <a
        href="#"
        data-network="linkedin"
        target="_blank"
        rel="noopener noreferrer"
        class="share-link text-text-800 flex items-center gap-3 px-4 py-3 text-xs transition-colors duration-200 hover:bg-gray-200">
        <i class="pi pi-linkedin text-base text-[#0A66C2]"></i>
        <span>Share on LinkedIn</span>
      </a>

      <a
        href="#"
        data-network="facebook"
        target="_blank"
        rel="noopener noreferrer"
        class="share-link text-text-800 border-border-light flex items-center gap-3 border-t px-4 py-3 text-xs transition-colors duration-200 hover:bg-gray-200">
        <i class="pi pi-facebook text-base text-[#1877F2]"></i>
        <span>Share on Facebook</span>
      </a>

      <a
        href="#"
        data-network="twitter"
        target="_blank"
        rel="noopener noreferrer"
        class="share-link text-text-800 border-border-light flex items-center gap-3 border-t px-4 py-3 text-xs transition-colors duration-200 hover:bg-gray-200">
        <i class="pi pi-twitter text-base text-[#000000]"></i>
        <span>Share on X (Twitter)</span>
      </a>

      <button
        type="button"
        class="copy-link-btn text-text-800 border-border-light flex w-full cursor-pointer items-center gap-3 border-t px-4 py-3 text-left text-xs transition-colors duration-200 hover:bg-gray-200">
        <i class="pi pi-link text-accent-300 text-base"></i>
        <span class="copy-link-text">Copy hyperlink</span>
      </button>
    </div>
  </div>
</div>

<script>
  import getSharingLink from '~/utils/share-link/getSharingLink';
  import type { ShareParams } from '~/interfaces/share-params.interface';

  function initSocialShareLinks() {
    document.querySelectorAll('.social-share-container').forEach(container => {
      const sharePath = container.getAttribute('data-share-path') || '';
      const shareTitle = container.getAttribute('data-share-title') || 'Check out this innovation';

      const shareUrl = sharePath.startsWith('http') ? sharePath : `${window.location.origin}${sharePath}`;

      container.querySelectorAll('.share-link').forEach(link => {
        const network = link.getAttribute('data-network') as ShareParams['network'];

        const shareParams: ShareParams = { url: shareUrl, network };
        if (network === 'twitter' || network === 'linkedin') {
          shareParams.title = shareTitle;
        }
        if (network === 'twitter') {
          shareParams.hashtags = 'Innovation,Research,AICCRA';
        }

        link.setAttribute('href', getSharingLink(shareParams));
      });

      const copyButton = container.querySelector('.copy-link-btn');
      if (copyButton && copyButton.dataset.copyBound !== 'true') {
        copyButton.dataset.copyBound = 'true';
        copyButton.addEventListener('click', async e => {
          e.preventDefault();
          const textSpan = copyButton.querySelector('.copy-link-text');

          if (textSpan) {
            try {
              await navigator.clipboard.writeText(shareUrl);
              const originalText = textSpan.textContent;
              textSpan.textContent = 'Copied!';

              setTimeout(() => {
                textSpan.textContent = originalText;
              }, 2000);
            } catch (err) {
              console.error('Failed to copy:', err);
              textSpan.textContent = 'Failed to copy';
              setTimeout(() => {
                textSpan.textContent = 'Copy hyperlink';
              }, 2000);
            }
          }
        });
      }
    });
  }

  initSocialShareLinks();
  document.addEventListener('DOMContentLoaded', initSocialShareLinks);
  document.addEventListener('astro:page-load', initSocialShareLinks);
</script>

<style>
  .social-share-container {
    position: relative;
  }

  .dropdown-wrapper {
    min-width: 100%;
  }

  .social-share-container:hover .dropdown-wrapper,
  .dropdown-wrapper:hover {
    display: block;
  }
</style>
