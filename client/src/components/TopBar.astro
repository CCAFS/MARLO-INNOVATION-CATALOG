---
import InnovationLogo from '../images/logo_aiccra_minimize.svg';
---

<header class="fixed top-0 left-0 z-50 w-full bg-white/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-screen-2xl items-center justify-between gap-4 px-6 py-3 lg:px-10">
    <a href="/" class="flex items-center gap-3">
      <InnovationLogo width={182} height={75} />
      <!-- <span class="text-text-700 text-base leading-tight font-semibold lg:text-lg">AICCRA E-catalog</span> -->
    </a>

    <a
      href="https://aiccra.cgiar.org/"
      target="_blank"
      rel="noopener noreferrer"
      class="bg-primary-500 hover:bg-primary-400 rounded-full px-4 py-2 text-sm font-semibold whitespace-nowrap text-white transition-colors">
      Go to AICCRA Website
    </a>
  </div>
</header>
