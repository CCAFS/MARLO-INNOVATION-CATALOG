---
import HeroBg from '~/images/hero-bg.png';
import { texts } from '../../../content/texts';
import StatsBar from './StatsBar.astro';
---

<section class="relative left-1/2 flex w-screen -translate-x-1/2 flex-col items-center justify-center gap-4 overflow-hidden pt-24 pb-8">
  <div class="absolute inset-0 bg-cover bg-center bg-no-repeat" style={`background-image: url(${HeroBg.src});`} aria-hidden="true"></div>
  <div class="absolute inset-0 bg-linear-to-b from-[#0d4a4a]/50 via-[#0d4a4a]/25 to-transparent" aria-hidden="true"></div>
  <div class="flex flex-col items-center justify-center gap-6">
    <h1
      class="relative z-10 max-w-4xl px-6 text-center text-xl leading-tight font-bold tracking-wide text-white uppercase sm:text-2xl md:text-3xl lg:text-4xl">
      {texts.home.overviewStats.title}
    </h1>
    <p class="relative z-10 max-w-2xl px-6 text-center text-base leading-tight font-medium tracking-wide text-white md:text-xl">
      {texts.home.overviewStats.subtitle}
    </p>

    <a
      href="#innovation-catalog"
      class="relative z-10 mb-12 max-w-5xl rounded-full bg-[#079899] px-4 py-3 text-center text-sm leading-tight font-medium tracking-wide text-white transition-colors hover:bg-[#066f70] lg:px-6 lg:py-3 lg:text-base">
      {texts.home.overviewStats.cta}
    </a>
  </div>

  <StatsBar />
</section>
