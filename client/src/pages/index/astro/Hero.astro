---
import { texts } from '../../../content/texts';
import StatsBar from './StatsBar.astro';
---

<section class="relative w-screen left-1/2 -translate-x-1/2 flex flex-col gap-4 items-center justify-center overflow-hidden pt-24 pb-8">
  <div class="absolute inset-0 bg-[#0d4a4a]/70" aria-hidden="true"></div>
  <div class="flex flex-col gap-6 items-center justify-center">
    <h1
      class="relative z-10 px-6 text-center text-white font-bold uppercase text-xl sm:text-2xl md:text-3xl lg:text-4xl max-w-4xl leading-tight tracking-wide">
      {texts.home.overviewStats.title}
    </h1>
    <p class="relative z-10 px-6 text-center text-white font-medium text-base md:text-xl max-w-2xl leading-tight tracking-wide">
      {texts.home.overviewStats.subtitle}
    </p>

    <a
      href="#innovation-catalog"
      class="relative z-10 px-4 py-3 lg:px-6 lg:py-3 mb-12 text-center text-white font-medium text-sm lg:text-base max-w-5xl leading-tight tracking-wide bg-[#0C5235] rounded-full hover:bg-[#0c593d] transition-colors">
      {texts.home.overviewStats.cta}
    </a>
  </div>

  <StatsBar />
</section>
